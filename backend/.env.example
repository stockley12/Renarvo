APP_NAME=Renarvo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=renarvo
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@renarvo.com"
MAIL_FROM_NAME="${APP_NAME}"

# JWT
JWT_SECRET=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Frontend
FRONTEND_URL=http://localhost:8080
ALLOWED_ORIGINS="http://localhost:8080,http://localhost:5173"

# FX
FX_API_URL=https://open.er-api.com/v6/latest/TRY
FX_BASE_CURRENCY=TRY

# Platform
PLATFORM_KDV_BPS=1800
PLATFORM_COMMISSION_BPS=1200
PLATFORM_SERVICE_FEE_KURUS=12000

# Payments (v2 — leave empty until provider is selected)
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
IYZICO_WEBHOOK_SECRET=
IYZICO_API_KEY=
IYZICO_API_SECRET=

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
